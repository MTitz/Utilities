#!/bin/bash
basename=${0##*/}
if [[ -z "$@" ]]; then
    echo "$basename: Missing argument"
elif [[ -d "$@" ]]; then
    echo "$basename: '$@' is a directory"
elif [[ -r "$@" ]]; then
    length=`winsize --columns`
    if [[ $length -gt 80 ]]; then
        length=$((length-1))
    fi
    fmt -s -w${length} "$@"|less
elif [[ -f "$@" ]]; then
    echo "$basename: Cannot read file '$@'"
else
    echo "$basename: file '$@' does not exist"
fi
